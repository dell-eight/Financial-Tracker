{
  "expo": {
    "name": "financial-tracker",
    "slug": "financial-tracker",
    "scheme": "financialtracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.financialtracker.app",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSPinnedDomains": {
            "supabase.co": {
              "NSIncludesSubdomains": true,
              "NSPinnedCAIdentities": [
                { "SPKI-SHA256-BASE64": "kIdp6NNEd8wsugYyyIYFsi1ylMCED3hZbSR8ZFsa/A4=" },
                { "SPKI-SHA256-BASE64": "mEflZT5enoR1FuXLgYYGqnVEoZvmf9c2bVBpiOjYQ0c=" }
              ]
            }
          }
        }
      }
    },
    "android": {
      "package": "com.financialtracker.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "color": "#755DEF",
          "defaultChannel": "budget-alerts",
          "sounds": []
        }
      ],
      "@react-native-community/datetimepicker",
      "./plugins/withAndroidNetworkSecurity"
    ]
  }
}
